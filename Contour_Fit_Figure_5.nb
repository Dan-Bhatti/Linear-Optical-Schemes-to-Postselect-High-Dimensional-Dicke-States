Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Find", " ", "the", " ", "values", " ", "for", " ", "which", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "36", ")"}]}]}], " ", "=", " ", 
    RowBox[{"Eq", ".", " ", 
     RowBox[{"(", "10", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", 
     RowBox[{"i", "<=", "5"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"T2", "[", "i", "]"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "n"}], "}"}], "/.", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"n", "!"}], "/", 
            SuperscriptBox["n", "n"]}], ")"}], "==", 
          RowBox[{"f2", "[", 
           RowBox[{"i", ",", "i"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{
            RowBox[{"10", "i"}], "-", "2"}]}], "}"}], ",", 
         RowBox[{"MaxIterations", "->", "250"}]}], "]"}]}]}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A2", "=", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"T2", "[", "#", "]"}], "&"}], ",", "5"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Fit", " ", "a", " ", "linear", " ", "function", " ", "to", " ", "the", 
     " ", "found", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"fit2", "=", 
    RowBox[{"LinearModelFit", "[", 
     RowBox[{"A2", ",", "x", ",", "x"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"fit2", "[", "\"\<ParameterTable\>\"", "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"plot221", "=", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"fit2", "[", "x", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "1", ",", "10"}], "}"}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", "A2", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot22", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fit2", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1", ",", "10"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", 
          RowBox[{"Dashing", "[", 
           RowBox[{"0.03", ",", "0.05", ",", "0.03"}], "]"}]}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"All", ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "50"}], "}"}]}], "}"}]}]}], "]"}]}], 
    ";"}]}]}]], "Input",
