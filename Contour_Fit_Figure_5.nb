Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Definition", " ", "of", " ", "qutrit", " ", "functions"}], "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Eq", ".", " ", 
       RowBox[{"(", "35", ")"}]}], " ", "with", " ", "N"}], "=", "n"}], ",", 
    " ", 
    RowBox[{"k2", "=", "k2"}], ",", " ", 
    RowBox[{"k1", "=", "k"}], ",", " ", 
    RowBox[{"k0", "=", 
     RowBox[{"n", "-", "k1", "-", "k2"}]}], ",", " ", 
    RowBox[{"we", " ", "ignore", " ", "the", " ", "minimum", " ", "here"}], 
    ",", " ", 
    RowBox[{
     RowBox[{
     "because", " ", "we", " ", "restrict", " ", "ourselves", " ", "to", " ", 
      "cases", " ", "with", " ", "k1"}], " ", "=", " ", 
     RowBox[{"k2", " ", "<", " ", 
      RowBox[{"n", "-", "k1", "-", "k2"}]}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"e2", "[", 
      RowBox[{"k1_", ",", "k2_"}], "]"}], "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"n", "!"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "k1", "-", "k2"}], ")"}], "!"}], 
        RowBox[{"k1", "!"}], 
        RowBox[{"k2", "!"}]}], 
       RowBox[{
        SuperscriptBox["n", "n"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"n", "-", "k1", "-", "k2"}], ")"}], 
         RowBox[{"n", "-", "k1", "-", "k2"}]], 
        SuperscriptBox["k1", "k1"], 
        SuperscriptBox["k2", "k2"]}]], "k2"}]}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"Eq", ".", " ", 
        RowBox[{"(", "36", ")"}]}], " ", "with", " ", "N"}], "=", "n"}], ",", 
     " ", 
     RowBox[{"k2", "=", "k2"}], ",", " ", 
     RowBox[{"k1", "=", "k"}], ",", " ", 
     RowBox[{"k0", "=", 
      RowBox[{"n", "-", "k1", "-", "k2"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"f2", "[", 
      RowBox[{"k1_", ",", "k2_"}], "]"}], "=", 
     RowBox[{
      FractionBox[
       RowBox[{
        RowBox[{"n", "!"}], 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"k1", "+", "k2"}], ")"}], "!"}]}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "k1", "-", "k2"}], ")"}], "!"}]], 
      FractionBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"n", "-", "k1", "-", "k2"}], ")"}], 
         RowBox[{"n", "-", "k1", "-", "k2"}]], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"k1", "+", "k2"}], ")"}], 
         RowBox[{"k1", "+", "k2"}]]}], 
       SuperscriptBox["n", 
        RowBox[{"n", "+", 
         RowBox[{"2", 
          RowBox[{"(", 
           RowBox[{"k1", "+", "k2"}], ")"}]}]}]]], 
      FractionBox[
       RowBox[{
        RowBox[{"k1", "!"}], 
        RowBox[{"k2", "!"}]}], 
       RowBox[{
        SuperscriptBox["k1", "k1"], 
        SuperscriptBox["k2", "k2"]}]], "n"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Plot", " ", "the", " ", "regions", " ", "where", " ", 
       RowBox[{"Eq", ".", " ", 
        RowBox[{"(", "36", ")"}]}]}], " ", ">=", " ", 
