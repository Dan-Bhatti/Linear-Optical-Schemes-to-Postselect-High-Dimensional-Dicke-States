Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Find", " ", "the", " ", "values", " ", "for", " ", "which", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "36", ")"}]}]}], " ", "=", " ", 
    RowBox[{"Eq", ".", " ", 
     RowBox[{"(", "35", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", 
     RowBox[{"i", "<=", "10"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"T", "[", "i", "]"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "n"}], "}"}], "/.", 
       RowBox[{"FindRoot", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"e2", "[", 
           RowBox[{"i", ",", "i"}], "]"}], "==", 
          RowBox[{"f2", "[", 
           RowBox[{"i", ",", "i"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", 
           RowBox[{
            RowBox[{"2", "i"}], "+", "1"}]}], "}"}], ",", 
         RowBox[{"MaxIterations", "->", "250"}]}], "]"}]}]}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"A", "=", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"T", "[", "#", "]"}], "&"}], ",", "10"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Fit", " ", "a", " ", "linear", " ", "function", " ", "to", " ", "the", 
     " ", "found", " ", "values"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"fit", "=", 
    RowBox[{"LinearModelFit", "[", 
     RowBox[{"A", ",", "x", ",", "x"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"fit", "[", "\"\<ParameterTable\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{"plot321", "=", 
    RowBox[{"Show", "[", 
     RowBox[{
      RowBox[{"Plot", "[", 
       RowBox[{
        RowBox[{"fit", "[", "x", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}], ",", 
      RowBox[{"ListPlot", "[", "A", "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot32", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fit", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "1", ",", "10"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Black", ",", 
          RowBox[{"Dashing", "[", 
           RowBox[{"0.01", ",", "0.01"}], "]"}]}], "}"}]}]}], "]"}]}], 
