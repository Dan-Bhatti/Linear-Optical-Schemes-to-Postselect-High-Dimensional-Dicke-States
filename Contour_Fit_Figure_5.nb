       RowBox[{"(", "10", ")"}]}]}], ",", " ", 
     RowBox[{
      RowBox[{"and", " ", 
       RowBox[{"Eq", ".", " ", 
        RowBox[{"(", "36", ")"}]}]}], " ", ">=", " ", 
      RowBox[{"Eq", ".", " ", 
       RowBox[{"(", "35", ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"plot12", "=", 
    RowBox[{"RegionPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Piecewise", "[", 
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"n", "!"}], "/", 
                SuperscriptBox["n", "n"]}], ")"}], "-", 
              RowBox[{"f2", "[", 
               RowBox[{"k", ",", "k"}], "]"}]}], "<=", "0"}], ",", 
            RowBox[{"k", "<", 
             RowBox[{"n", "-", 
              RowBox[{"2", "k"}]}]}]}], "}"}], "}"}], "]"}], ",", 
        RowBox[{"Piecewise", "[", 
