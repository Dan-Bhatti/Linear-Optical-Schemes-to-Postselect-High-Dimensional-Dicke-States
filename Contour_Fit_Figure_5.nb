          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"e2", "[", 
               RowBox[{"k", ",", "k"}], "]"}], "-", 
              RowBox[{"f2", "[", 
               RowBox[{"k", ",", "k"}], "]"}]}], "<=", "0"}], ",", 
            RowBox[{"k", "<", 
             RowBox[{"n", "-", 
              RowBox[{"2", "k"}]}]}]}], "}"}], "}"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "1", ",", "10"}], "}"}], ",", 
