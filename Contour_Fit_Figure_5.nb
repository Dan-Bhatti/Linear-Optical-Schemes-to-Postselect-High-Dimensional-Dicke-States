       RowBox[{
        SuperscriptBox["n", "n"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"n", "-", "k"}], ")"}], 
         RowBox[{"n", "-", "k"}]], 
        SuperscriptBox["k", "k"]}]], "k"}]}], ";"}], "\[IndentingNewLine]", 
